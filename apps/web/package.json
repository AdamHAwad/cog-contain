{
	"name": "@cog-contain/web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "pnpm run prepare-local-site && vite dev",
		"build": "pnpm run prepare-local-site && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"qa:skatebench-visualizer": "node --experimental-strip-types scripts/validateSkatebenchVisualizer.ts",
		"qa:tui-dry-run-summary": "node --experimental-strip-types scripts/validateCogContainTuiDryRun.ts",
		"qa:tui-mock-summary": "node --experimental-strip-types scripts/validateCogContainTuiMockSummary.ts",
		"qa:public-result-summary": "node --experimental-strip-types scripts/validatePublicResultSummary.ts",
		"qa:result-isolation": "node --experimental-strip-types scripts/validateResultIsolation.ts",
		"qa:front-facing-copy": "node --experimental-strip-types scripts/validateFrontFacingCopy.ts",
		"qa:scenario-exposure": "node --experimental-strip-types scripts/validateScenarioExposure.ts",
		"prepare-local-site": "node --experimental-strip-types scripts/prepareLocalSite.ts",
		"qa:site-result-snapshot": "node --experimental-strip-types scripts/validateSiteResultSnapshot.ts",
		"prepare-public-site": "node --experimental-strip-types scripts/preparePublicSite.ts && node --experimental-strip-types scripts/validatePublicResultSummary.ts && node --experimental-strip-types scripts/validateSiteResultSnapshot.ts",
		"build:public-site": "COG_CONTAIN_STATIC_BUILD=true pnpm run prepare-public-site && COG_CONTAIN_STATIC_BUILD=true vite build && COG_CONTAIN_STATIC_BUILD=true node --experimental-strip-types scripts/validateSkatebenchVisualizer.ts"
	},
	"devDependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@lucide/svelte": "^1.16.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.9.1",
		"clsx": "^2.1.1",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@cog-contain/core": "workspace:^"
	},
	"license": "MIT"
}
