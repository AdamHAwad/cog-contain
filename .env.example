# COG-CONTAIN local development variables.
# Copy to .env locally and fill values there. Never commit real secrets.

OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Convex/SvelteKit values will be filled after verified framework setup.
CONVEX_DEPLOYMENT=
PUBLIC_CONVEX_URL=
PUBLIC_CONVEX_SITE_URL=
VITE_CONVEX_URL=
PUBLIC_SITE_ORIGIN=http://localhost:5173

# Owner/admin controls for official hidden-eval workflows.
COG_CONTAIN_ADMIN_EMAILS=
COG_CONTAIN_ADMIN_TOKEN_IDENTIFIERS=
COG_CONTAIN_OFFICIAL_RUNS_ENABLED=false
